APP_NAME=Salmon Water Risk Backend
APP_VERSION=0.1.0
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

ARTIFACTS_DIR=artifacts
CACHE_DIR=artifacts/cache
CACHE_MAX_SIZE_GB=10
CLIPPED_CACHE_MAX_DIMENSION=2048
CACHE_DEFAULT_DATASET=sentinel2
SCENE_REGISTRY_PATH=artifacts/registry/scenes.json
PROCESSED_REGISTRY_PATH=artifacts/registry/processed_scenes.json
TRAINING_REGISTRY_PATH=artifacts/registry/training_jobs.json
PREDICTION_REGISTRY_PATH=artifacts/registry/predictions.json
MODEL_ARTIFACTS_DIR=artifacts/models
MIGRATION_PATHS_FILE=data/migration_paths/salmon_paths.geojson

NDWI_WATER_THRESHOLD=0.0
WATER_NIR_TO_GREEN_RATIO_MAX=1.15
WATER_NDVI_MAX=0.15
MIN_TILE_WATER_FRACTION_FOR_RISK=0.20
WATER_DETECTOR_MODE=spectral
PRETRAINED_WATER_MODEL_REPO_ID=geoai4cities/sentinel2-water-segmentation
HUGGINGFACE_TOKEN=
HEATMAP_YELLOW_THRESHOLD=0.30
HEATMAP_RED_THRESHOLD=0.65
HEATMAP_INFRARED_THRESHOLD=0.85
DEFAULT_GRID_BLOCK_SIZE=32
DEFAULT_MIGRATION_BUFFER_METERS=250.0
DEFAULT_INFERENCE_TILE_SIZE=256
DEFAULT_INFERENCE_BATCH_SIZE=8

SENTINEL_API_URL=https://example-sentinel-provider.local
SENTINEL_API_KEY=

PRITHVI_MODEL_NAME=ibm-nasa-geospatial/Prithvi-EO-1.0-100M
PRITHVI_ENABLED=false
